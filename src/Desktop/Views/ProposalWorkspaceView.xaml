<UserControl x:Class="QuotationAccelerator.Desktop.Views.ProposalWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:QuotationAccelerator.Desktop.Controls"
             Background="{StaticResource PageBackgroundBrush}">
  <ScrollViewer Padding="32">
    <StackPanel MaxWidth="1100" HorizontalAlignment="Center">
      <TextBlock Text="{Binding Heading}" Style="{StaticResource PageTitleStyle}" />
      <TextBlock Text="{Binding Subtitle}" Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,16" />

      <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
        <Button Content="{Binding CopyToClipboardButtonText}"
                Command="{Binding CopyToClipboardCommand}"
                Style="{StaticResource PrimaryButtonStyle}"
                Margin="0,0,8,0" />
        <Button Content="{Binding OpenProjectFolderButtonText}"
                Command="{Binding OpenProjectFolderCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,0,8,0" />
        <Button Content="{Binding OpenDrawingButtonText}"
                Command="{Binding OpenDrawingCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                IsEnabled="{Binding CanOpenDrawing}" />
      </StackPanel>

      <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="{Binding ManufacturingStepsGroup}" Style="{StaticResource SectionTitleStyle}" />
          <TextBox Text="{Binding ManufacturingSteps, UpdateSourceTrigger=PropertyChanged}"
                   AcceptsReturn="True"
                   MinHeight="140"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="{Binding SuggestedQuotationGroup}" Style="{StaticResource SectionTitleStyle}" />
          <TextBox Text="{Binding SuggestedQuotation, UpdateSourceTrigger=PropertyChanged}"
                   AcceptsReturn="True"
                   MinHeight="140"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="{Binding ReferencedDocumentsGroup}" Style="{StaticResource SectionTitleStyle}" />
          <TextBox Text="{Binding ReferencedDocuments, UpdateSourceTrigger=PropertyChanged}"
                   AcceptsReturn="True"
                   MinHeight="100"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="{Binding DocumentPreviewGroup}" Style="{StaticResource SectionTitleStyle}" />
          <controls:PdfPreviewControl SourcePath="{Binding PreviewPdfPath}"
                                      PlaceholderMessage="{Binding PreviewPlaceholderMessage}"
                                      RuntimeMissingMessage="{Binding PdfPreviewRuntimeMissingMessage}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CollapsibleInfoBannerStyle}">
        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
