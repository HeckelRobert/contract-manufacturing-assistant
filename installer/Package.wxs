<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Quotation Accelerator"
           Manufacturer="Heckel Informatik GmbH"
           Version="$(var.ProductVersion)"
           UpgradeCode="c8f4e2a1-5b3d-4e6f-9a2c-1d8e7f6a5b4c"
           Scope="perMachine">

    <MajorUpgrade AllowDowngrades="no"
                  DowngradeErrorMessage="A newer version of Quotation Accelerator is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectDir)License.rtf" />

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Quotation Accelerator" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Quotation Accelerator" />
    </StandardDirectory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="b8c9d0e1-f2a3-4567-8901-234567890abc">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="Quotation Accelerator"
                  Description="Manufacturing quotation preparation prototype"
                  Target="[INSTALLFOLDER]Quotation Accelerator.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Heckel Informatik\Quotation Accelerator"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="Main" Title="Quotation Accelerator" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>
</Wix>
