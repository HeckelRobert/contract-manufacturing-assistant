<UserControl x:Class="QuotationAccelerator.Desktop.Controls.PdfPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinHeight="420">
  <Grid>
    <wv2:WebView2 x:Name="PreviewWebView"
                  Visibility="Collapsed" />
    <Border Background="#F8FAFC"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsPlaceholderVisible, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <TextBlock x:Name="PlaceholderText"
                 TextWrapping="Wrap"
                 TextAlignment="Center"
                 VerticalAlignment="Center"
                 Foreground="{StaticResource MutedForegroundBrush}" />
    </Border>
  </Grid>
</UserControl>
