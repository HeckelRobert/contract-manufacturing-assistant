<UserControl x:Class="QuotationAccelerator.Desktop.Views.InboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBackgroundBrush}">
  <ScrollViewer Padding="32">
    <StackPanel HorizontalAlignment="Stretch">
      <TextBlock Text="{Binding Heading}" Style="{StaticResource PageTitleStyle}" />
      <TextBlock Text="{Binding Subtitle}" Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,16" />

      <Border Style="{StaticResource CollapsibleInfoBannerStyle}" Margin="0,0,0,16">
        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </Border>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
        <Button Content="{Binding FetchMailButtonText}"
                Command="{Binding FetchMailCommand}"
                Style="{StaticResource PrimaryButtonStyle}"
                MinWidth="0"
                Margin="0,0,12,0" />
        <Button Content="{Binding ClearInboxCacheButtonText}"
                Command="{Binding ClearInboxCacheCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,0,12,0" />
        <ComboBox ItemsSource="{Binding FilterOptions}"
                  SelectedItem="{Binding SelectedFilter}"
                  MinWidth="220" />
      </StackPanel>

      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.2*" MinWidth="420" />
          <ColumnDefinition Width="*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
          <ListBox ItemsSource="{Binding Messages}"
                   SelectedItem="{Binding SelectedMessage}"
                   DisplayMemberPath="Subject"
                   Background="Transparent" />
        </Border>

        <StackPanel Grid.Column="1">
          <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="{Binding SelectedMessage.Subject}"
                         Style="{StaticResource SectionTitleStyle}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,8" />
              <TextBlock Text="{Binding SelectedMessage.FromDisplay}" TextWrapping="Wrap" Margin="0,0,0,8" />
              <TextBlock Text="{Binding SelectedMessage.CategoryDisplay}" Margin="0,0,0,8" />
              <TextBlock Text="{Binding SelectedMessage.AttachmentsDisplay}" Margin="0,0,0,8" />
              <TextBlock Text="{Binding SelectedMessage.BodyPreview}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,12" />
              <TextBlock Text="{Binding InboxReplyPreviewLabel}" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6" />
              <TextBox Text="{Binding ReplyPreviewBody, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="100"
                       Margin="0,0,0,12" />
              <WrapPanel>
                <Button Content="{Binding ContinueInquiryButtonText}"
                        Command="{Binding ContinueInquiryCommand}"
                        IsEnabled="{Binding CanContinueInquiry}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="0"
                        Margin="0,0,8,8" />
                <Button Content="{Binding SendAutoReplyButtonText}"
                        Command="{Binding SendAutoReplyCommand}"
                        IsEnabled="{Binding CanSendAutoReply}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="0"
                        Margin="0,0,8,8" />
                <Button Content="{Binding EscalateToSupportButtonText}"
                        Command="{Binding EscalateToSupportCommand}"
                        IsEnabled="{Binding CanEscalateToSupport}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="0"
                        Margin="0,0,8,8" />
              </WrapPanel>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource CardBorderStyle}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top"
                         Text="{Binding SupportQueueGroup}"
                         Style="{StaticResource SectionTitleStyle}"
                         Margin="0,0,0,8" />
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <Button Content="{Binding MarkSupportResolvedButtonText}"
                        Command="{Binding MarkSupportResolvedCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
              </StackPanel>
              <ListBox ItemsSource="{Binding SupportTickets}"
                       SelectedItem="{Binding SelectedSupportTicket}"
                       DisplayMemberPath="Subject"
                       MaxHeight="140"
                       Background="Transparent" />
            </DockPanel>
          </Border>
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
