<Window x:Class="QuotationAccelerator.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:QuotationAccelerator.Desktop.Views"
        Title="{Binding WindowTitle}"
        Height="900"
        Width="1280"
        MinHeight="700"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app-icon.ico"
        Background="{StaticResource PageBackgroundBrush}">
  <TabControl SelectedIndex="{Binding SelectedTabIndex}" Background="{StaticResource PageBackgroundBrush}">
    <TabItem Header="{Binding TabInboxHeader}">
      <views:InboxView DataContext="{Binding Inbox}" />
    </TabItem>
    <TabItem Header="{Binding TabInquiryHeader}">
      <views:InquiryView DataContext="{Binding Inquiry}" />
    </TabItem>
    <TabItem Header="{Binding TabResultsHeader}">
      <views:ResultsView DataContext="{Binding Results}" />
    </TabItem>
    <TabItem Header="{Binding TabProposalWorkspaceHeader}">
      <views:ProposalWorkspaceView DataContext="{Binding ProposalWorkspace}" />
    </TabItem>
    <TabItem Header="{Binding TabSettingsHeader}">
      <views:SettingsView DataContext="{Binding Settings}" />
    </TabItem>
  </TabControl>
</Window>
