<UserControl x:Class="QuotationAccelerator.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:QuotationAccelerator.Desktop.Views"
             Background="{StaticResource PageBackgroundBrush}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <Style x:Key="SettingsNavListBoxStyle" TargetType="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="SettingsNavListBoxItemStyle" TargetType="ListBoxItem">
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="ItemBorder"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource InfoBackgroundBrush}" />
                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="#F8FAFC" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="{Binding Heading}" Style="{StaticResource PageTitleStyle}" />

    <Grid Grid.Row="1" Margin="0,24,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />
        <ColumnDefinition Width="24" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <ListBox Grid.Column="0"
               ItemsSource="{Binding NavItems}"
               SelectedItem="{Binding SelectedNavItem}"
               DisplayMemberPath="Label"
               Style="{StaticResource SettingsNavListBoxStyle}"
               ItemContainerStyle="{StaticResource SettingsNavListBoxItemStyle}" />

      <ScrollViewer Grid.Column="2"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding IsGeneralSectionSelected, Converter={StaticResource BoolToVisibility}}">
        <StackPanel HorizontalAlignment="Stretch">
          <Border Style="{StaticResource CollapsibleInfoBannerStyle}" Margin="0,0,0,16">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          </Border>

          <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
              <TextBlock Text="{Binding ProjectCatalogGroup}" Style="{StaticResource SectionTitleStyle}" />
              <DockPanel Margin="0,0,0,12">
                <Button Content="{Binding BrowseButtonText}"
                        Command="{Binding BrowseProjectRootCommand}"
                        DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <TextBox Text="{Binding ProjectRoot, UpdateSourceTrigger=PropertyChanged}" />
              </DockPanel>
              <TextBlock Text="{Binding IndexedProjectsLabel}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,12" />
              <Button Content="{Binding RescanProjectsButtonText}"
                      Command="{Binding RescanCommand}"
                      HorizontalAlignment="Left"
                      Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
          </Border>

          <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
              <TextBlock Text="{Binding MailSettingsGroup}" Style="{StaticResource SectionTitleStyle}" />
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="200" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding MailTenantIdLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MailTenantId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding MailClientIdLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MailClientId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding MailMailboxLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MailMailboxAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding MailFolderLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MailFolderName, UpdateSourceTrigger=PropertyChanged}" />
              </Grid>
              <TextBlock Text="{Binding MailConnectionStatus}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,12" />
              <StackPanel Orientation="Horizontal">
                <Button Content="{Binding SaveMailSettingsButtonText}"
                        Command="{Binding SaveMailSettingsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="{Binding ConnectMailButtonText}"
                        Command="{Binding ConnectMailCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="{Binding DisconnectMailButtonText}"
                        Command="{Binding DisconnectMailCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
              <TextBlock Text="{Binding AiProviderStatusGroup}" Style="{StaticResource SectionTitleStyle}" />
              <TextBlock Text="{Binding AiProviderStatus}"
                         FontFamily="Consolas"
                         TextWrapping="Wrap"
                         LineHeight="22" />
            </StackPanel>
          </Border>

          <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ChatModelLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ChatModel}" IsReadOnly="True" Margin="0,0,0,12" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding EmbeddingModelLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EmbeddingModel}" IsReadOnly="True" Margin="0,0,0,12" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding MatchingStrategyLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
              <ComboBox Grid.Row="2" Grid.Column="1"
                        ItemsSource="{Binding MatchingStrategies}"
                        SelectedItem="{Binding MatchingStrategy}"
                        Margin="0,0,0,12" />

              <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding UiLanguageLabel}" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" />
              <ComboBox Grid.Row="3" Grid.Column="1"
                        ItemsSource="{Binding UiLanguages}"
                        SelectedItem="{Binding UiLanguage}" />
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Column="2"
              Visibility="{Binding IsMailResponsesSectionSelected, Converter={StaticResource BoolToVisibility}}">
        <views:MailResponsesView DataContext="{Binding MailResponses}" />
      </Border>
    </Grid>
  </Grid>
</UserControl>
