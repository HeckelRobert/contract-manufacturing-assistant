<UserControl x:Class="QuotationAccelerator.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Padding="24">
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
      <TextBlock Text="{Binding Heading}"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Margin="0,0,0,16" />

      <GroupBox Header="{Binding ProjectCatalogGroup}">
        <StackPanel>
          <DockPanel Margin="0,0,0,8">
            <Button Content="{Binding BrowseButtonText}"
                    Command="{Binding BrowseProjectRootCommand}"
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0" />
            <TextBox Text="{Binding ProjectRoot, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
          <TextBlock Text="{Binding IndexedProjectsLabel}"
                     Margin="0,0,0,8" />
          <Button Content="{Binding RescanProjectsButtonText}"
                  Command="{Binding RescanCommand}"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </GroupBox>

      <GroupBox Header="{Binding AiProviderStatusGroup}">
        <TextBlock Text="{Binding AiProviderStatus}"
                   FontFamily="Consolas"
                   TextWrapping="Wrap" />
      </GroupBox>

      <GroupBox Header="{Binding MatchingAndModelsGroup}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ChatModelLabel}" Margin="0,8" />
          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ChatModel}" Margin="0,8" IsReadOnly="True" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding EmbeddingModelLabel}" Margin="0,8" />
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EmbeddingModel}" Margin="0,8" IsReadOnly="True" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding MatchingStrategyLabel}" Margin="0,8" />
          <ComboBox Grid.Row="2" Grid.Column="1"
                    ItemsSource="{Binding MatchingStrategies}"
                    SelectedItem="{Binding MatchingStrategy}"
                    Margin="0,8" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding UiLanguageLabel}" Margin="0,8" />
          <ComboBox Grid.Row="3" Grid.Column="1"
                    ItemsSource="{Binding UiLanguages}"
                    SelectedItem="{Binding UiLanguage}"
                    Margin="0,8" />
        </Grid>
      </GroupBox>

      <TextBlock Text="{Binding StatusMessage}"
                 Margin="0,8,0,0"
                 TextWrapping="Wrap"
                 Foreground="#666666" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
