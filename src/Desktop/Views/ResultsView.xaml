<UserControl x:Class="QuotationAccelerator.Desktop.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBackgroundBrush}">
  <ScrollViewer Padding="32">
    <StackPanel MaxWidth="1100" HorizontalAlignment="Center">
      <TextBlock Text="{Binding ResultsHeading}" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,20" />

      <ItemsControl ItemsSource="{Binding Matches}">
        <ItemsControl.Style>
          <Style TargetType="ItemsControl">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasMatches}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ItemsControl.Style>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
              <StackPanel>
                <DockPanel Margin="0,0,0,8">
                  <Border DockPanel.Dock="Right"
                          Background="#ECFDF5"
                          BorderBrush="#A7F3D0"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="8,4">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsPrimaryMatch}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding PrimaryMatchBadge}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}" />
                  </Border>
                  <StackPanel>
                    <TextBlock Text="{Binding ProjectNumber}" FontWeight="SemiBold" FontSize="18" />
                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding FolderName}" FontSize="12" Foreground="{StaticResource MutedForegroundBrush}" />
                  </StackPanel>
                </DockPanel>
                <TextBlock Text="{Binding SimilarityLabel}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ReasonsText}" TextWrapping="Wrap" Foreground="{StaticResource ForegroundBrush}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Margin="0,0,0,0">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasMatches}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel HorizontalAlignment="Center" Margin="24">
          <TextBlock Text="{Binding EmptyTitle}"
                     FontSize="20"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,8" />
          <TextBlock Text="{Binding EmptySubtitle}"
                     Style="{StaticResource PageSubtitleStyle}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
