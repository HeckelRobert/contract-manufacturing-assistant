<UserControl x:Class="QuotationAccelerator.Desktop.Views.ProposalWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Padding="24">
    <StackPanel>
      <TextBlock Text="Proposal Workspace"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Margin="0,0,0,16" />

      <GroupBox Header="Manufacturing Steps">
        <TextBox Text="{Binding ManufacturingSteps, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 MinHeight="120"
                 TextWrapping="Wrap" />
      </GroupBox>

      <GroupBox Header="Suggested Quotation">
        <TextBox Text="{Binding SuggestedQuotation, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 MinHeight="120"
                 TextWrapping="Wrap" />
      </GroupBox>

      <GroupBox Header="Referenced Documents">
        <TextBox Text="{Binding ReferencedDocuments, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 MinHeight="80"
                 TextWrapping="Wrap" />
      </GroupBox>

      <GroupBox Header="Document Preview">
        <TextBlock Text="{Binding DocumentPreviewStatus}"
                   TextWrapping="Wrap" />
      </GroupBox>
    </StackPanel>
  </ScrollViewer>
</UserControl>
