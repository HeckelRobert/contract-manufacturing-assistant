<UserControl x:Class="QuotationAccelerator.Desktop.Views.MailResponsesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBackgroundBrush}">
  <Grid Margin="0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="{Binding Heading}" Style="{StaticResource PageTitleStyle}" />
      <TextBlock Text="{Binding Subtitle}" Style="{StaticResource PageSubtitleStyle}" Margin="0,8,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="1" Style="{StaticResource CollapsibleInfoBannerStyle}" Margin="0,0,0,16">
      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
      <Button Content="{Binding SaveButtonText}"
              Command="{Binding SaveTemplatesCommand}"
              Style="{StaticResource PrimaryButtonStyle}"
              Margin="0,0,8,0" />
      <Button Content="{Binding AddButtonText}"
              Command="{Binding AddTemplateCommand}"
              Style="{StaticResource SecondaryButtonStyle}"
              Margin="0,0,8,0" />
      <Button Content="{Binding RemoveButtonText}"
              Command="{Binding RemoveTemplateCommand}"
              IsEnabled="{Binding HasSelectedTemplate}"
              Style="{StaticResource SecondaryButtonStyle}" />
    </StackPanel>

    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" MinWidth="260" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" MinWidth="360" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top"
                     Text="{Binding ListLabel}"
                     Style="{StaticResource SectionTitleStyle}"
                     Margin="0,0,0,12" />
          <ListBox ItemsSource="{Binding Templates}"
                   SelectedItem="{Binding SelectedTemplate}"
                   DisplayMemberPath="ListDisplay"
                   Background="Transparent"
                   BorderThickness="0" />
        </DockPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
        <Grid>
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasSelectedTemplate}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="{Binding SelectPrompt}"
                       Style="{StaticResource PageSubtitleStyle}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="420" />
          </StackPanel>

          <StackPanel>
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasSelectedTemplate}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="{Binding KeywordsLabel}" Style="{StaticResource FieldLabelStyle}" />
            <TextBox Text="{Binding SelectedTemplate.KeywordsText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16" />
            <TextBlock Text="{Binding ReplyBodyLabel}" Style="{StaticResource FieldLabelStyle}" />
            <TextBox Text="{Binding SelectedTemplate.ReplyBody, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="280" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

  </Grid>
</UserControl>
